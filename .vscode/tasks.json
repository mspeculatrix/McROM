{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Flash STM32",
			"type": "shell",
			"command": "/Applications/STMicroelectronics/STM32Cube/STM32CubeProgrammer/STM32CubeProgrammer.app/Contents/MacOs/STM32CubeProgrammer",
			"args": [
				"-c",
				"port=SWD",
				"-w",
				"${workspaceFolder}/build/Debug/McROM.elf",
				"-v"
			],
			"group": {
				"kind": "build",
				"isDefault": "false"
			},
			"presentation": {
				"echo": true,
				"reveal": "always",
				"focus": false,
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"type": "cmake",
			"label": "STM32 CMake: build",
			"command": "build",
			"targets": [
				"all"
			],
			"preset": "Debug",
			"group": "build",
			"problemMatcher": [],
			"detail": "CMake template build task"
		},
		{
			"type": "cmake",
			"label": "STM32 CMake: clean",
			"command": "build",
			"targets": [
				"clean"
			],
			"preset": "Debug",
			"group": "build",
			"problemMatcher": [],
			"detail": "CMake template build task"
		}
	]
}